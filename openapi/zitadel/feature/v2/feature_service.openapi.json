    "/v2/features/system": {
      "get": {
        "tags": [
          "zitadel.feature.v2.FeatureService"
        ],
        "summary": "GetSystemFeatures",
        "description": "Get System Features\n\n Returns all configured features for the system. Unset fields mean the feature is the current system default.\n\n Required permissions:\n  - none",
        "operationId": "zitadel.feature.v2.FeatureService.GetSystemFeatures",
        "responses": {
          "default": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/connect.error"
                }
              }
            }
          },
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/zitadel.feature.v2.GetSystemFeaturesResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "zitadel.feature.v2.FeatureService"
        ],
        "summary": "SetSystemFeatures",
        "description": "Set System Features\n\n Configure and set features that apply to the complete system. Only fields present in the request are set or unset.\n\n Required permissions:\n  - system.feature.write",
        "operationId": "zitadel.feature.v2.FeatureService.SetSystemFeatures",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/zitadel.feature.v2.SetSystemFeaturesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "default": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/connect.error"
                }
              }
            }
          },
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/zitadel.feature.v2.SetSystemFeaturesResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "zitadel.feature.v2.FeatureService"
        ],
        "summary": "ResetSystemFeatures",
        "description": "Reset System Features\n\n Deletes ALL configured features for the system, reverting the behaviors to system defaults.\n\n Required permissions:\n  - system.feature.delete",
        "operationId": "zitadel.feature.v2.FeatureService.ResetSystemFeatures",
        "responses": {
          "default": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/connect.error"
                }
              }
            }
