    "/zitadel.group.v2.GroupService/AddUsersToGroup": {
      "post": {
        "tags": [
          "zitadel.group.v2.GroupService"
        ],
        "summary": "Add Users",
        "description": "Adds one or more users to a group.\n The users should be in the same organization as the group.\n The request will not fail if some of the users could not be added to the group,\n and a list of failed user IDs is available in the response.\n\n Required permissions:\n   - group.user.write",
        "operationId": "zitadel.group.v2.GroupService.AddUsersToGroup",
        "parameters": [
          {
            "name": "Connect-Protocol-Version",
            "in": "header",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/connect-protocol-version"
            }
          },
          {
            "name": "Connect-Timeout-Ms",
            "in": "header",
            "schema": {
              "$ref": "#/components/schemas/connect-timeout-header"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/zitadel.group.v2.AddUsersToGroupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "default": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/connect.error"
                }
              }
            }
          },
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/zitadel.group.v2.AddUsersToGroupResponse"
                }
              }
            }
          }
        }
      }
    },
