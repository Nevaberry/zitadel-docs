          "limit": {
            "type": "integer",
            "title": "limit",
            "description": "limit is the maximum amount of objects returned. The default is set to 100\n with a maximum of 1000 in the runtime configuration.\n If the limit exceeds the maximum configured Zitadel will throw an error.\n If no limit is present the default is taken."
          },
          "asc": {
            "type": "boolean",
            "title": "asc",
            "description": "Asc is the sorting order. If true the list is sorted ascending, if false\n the list is sorted descending. The default is descending."
          }
        },
